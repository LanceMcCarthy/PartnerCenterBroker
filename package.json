{
  "name": "@lancemccarthy/partner-center-broker",
  "version": "2026.227.0",
  "description": "A helper library that lets you manage your Microsoft Partner Center application submissions.",
  "main": "./lib/devCenter.js",
  "types": "./lib/devCenter.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('lib', { recursive: true, force: true })\"",
    "build": "tsc",
    "rebuild": "npm run clean && npm run build",
    "test": "jest",
    "docs-clean": "node -e \"require('fs').rmSync('docs', { recursive: true, force: true })\"",
    "docs-generate": "npm run docs-clean && typedoc src/ --out docs --excludePrivate",
    "format-write": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "prep": "npm run rebuild && npm run format-write && npm run test && npm run docs-generate",
    "package": "npm run prep && npm pack",
    "publish-docs": "npm run docs-generate && gh-pages -d docs -t",
    "publish-local": "npm run package && npm publish && npm run publish-docs",
    "publish-gh-actions": "npm ci && npm run prep && npm publish --access public && gh-pages -d docs -t"
  },
  "keywords": [
    "StoreBroker",
    "Microsoft",
    "Partner",
    "Center",
    "PartnerCenter",
    "Microsoft",
    "Store",
    "API",
    "Microsoft",
    "Store",
    "DevCenter",
    "DevCenter",
    "API"
  ],
  "author": "Lance McCarthy",
  "license": "GPL-3.0",
  "homepage": "https://github.com/LanceMcCarthy/PartnerCenterBroker#readme",
  "repository": {
    "type": "git",
    "url": "git://github.com/LanceMcCarthy/PartnerCenterBroker.git"
  },
  "bugs": {
    "url": "https://github.com/LanceMcCarthy/PartnerCenterBroker/issues"
  },
  "dependencies": {
    "got": "^11.5.2"
  },
  "devDependencies": {
    "@types/got": "^9.6.11",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "gh-pages": "^6.0.0",
    "jest": "^29.5.0",
    "jest-circus": "^29.5.0",
    "jest-junit": "^11.1.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "tslint": "^6.1.3",
    "tslint-config-standard": "^9.0.0",
    "typedoc": "^0.24.0",
    "typescript": "^5.0.0"
  }
}
